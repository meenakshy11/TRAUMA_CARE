# ============================================================
#  Integrated Trauma Care Platform — Web App (apps/web)
#  Environment Variables
#
#  Copy this file to .env.local and fill in real values.
#  Never commit .env.local to version control.
#  All variables MUST be prefixed with VITE_ to be exposed
#  to the browser bundle by Vite.
# ============================================================

# ─── API ────────────────────────────────────────────────────
# Base URL for the FastAPI backend (no trailing slash).
# In production this should be your public HTTPS domain.
# Dev default proxied by Vite: http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# API version prefix appended before all endpoint paths.
# Corresponds to FastAPI router mounted at /api/v1
VITE_API_VERSION=v1

# ─── WebSocket ──────────────────────────────────────────────
# WebSocket base URL for live event streams.
# Must use ws:// (dev) or wss:// (production).
# Vite dev server proxies /ws/* automatically; override for prod.
VITE_WS_BASE_URL=ws://localhost:8000

# ─── Auth ───────────────────────────────────────────────────
# Milliseconds before JWT expiry to trigger a silent refresh.
# Default: 60000 (60 seconds before expiry)
VITE_AUTH_REFRESH_BUFFER_MS=60000

# ─── Map / Tiles ────────────────────────────────────────────
# Tile server URL for Leaflet MapLibre.
# Default uses OpenStreetMap (free, no key required).
# For production consider a paid provider (Mapbox, Stadia, etc.)
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_TILE_ATTRIBUTION=© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors

# Default map center (Kerala, India — trauma platform focus area)
VITE_MAP_DEFAULT_LAT=10.8505
VITE_MAP_DEFAULT_LNG=76.2711
VITE_MAP_DEFAULT_ZOOM=8

# ─── Feature Flags ──────────────────────────────────────────
# Enable demo / offline mode. When true the app uses seeded
# mock data instead of live API calls. Useful for demos and CI.
VITE_DEMO_MODE=false

# Enable analytics dashboard route (GOVERNMENT / ADMIN only).
VITE_FEATURE_ANALYTICS=true

# Enable simulation module (ADMIN only).
VITE_FEATURE_SIMULATION=true

# Enable black spot registry module.
VITE_FEATURE_BLACKSPOTS=true

# Enable public citizen-reporting form (no auth required).
VITE_FEATURE_PUBLIC_REPORT=true

# Enable WebSocket real-time updates on the command center.
# Turn off for environments where WS is blocked (some proxies).
VITE_FEATURE_WEBSOCKET=true

# ─── Notifications ──────────────────────────────────────────
# How many seconds between polling for new notifications when
# WebSocket is disabled (fallback polling interval).
VITE_NOTIFICATION_POLL_INTERVAL_SEC=30

# ─── Logging & Monitoring ───────────────────────────────────
# Log level exposed to the browser console: debug | info | warn | error
VITE_LOG_LEVEL=info

# Optional Sentry DSN for error tracking (leave blank to disable).
VITE_SENTRY_DSN=

# Optional Sentry environment tag.
VITE_SENTRY_ENVIRONMENT=development

# ─── Misc ───────────────────────────────────────────────────
# Application display name used in page titles and headers.
VITE_APP_NAME="Integrated Trauma Care Platform"

# Support contact shown in error pages and footer.
VITE_SUPPORT_EMAIL=support@traumaplatform.example.com
